# ─── polygon-generation Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your own values.
# Never commit a .env file with real credentials.

PORT=8021
BASE_URL=http://localhost:8021

# MongoDB connection string
DATABASE_URL=mongodb://localhost:27017/geo_magic

# Password hashing pepper (use a long random string)
SALT_KEY=REPLACE_WITH_STRONG_RANDOM_STRING

# JWT signing secret (use a long random string)
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_STRING

# SMTP (Nodemailer) settings for OTP / transactional email
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_APP_NAME=polygon-generation
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
