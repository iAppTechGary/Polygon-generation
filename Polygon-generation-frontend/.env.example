# ─── polygon-generation Frontend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your own values.
# Never commit a .env file with real credentials.

# Node.js / Express backend base URL
VITE_API_URL=http://localhost:8021

# Python FastAPI service base URL
VITE_PYTHON_API_URL=http://localhost:5000

# Palette service URL (may be same as Python backend)
VITE_PALETTE_API_URL=http://localhost:5000

# External image-conversion service (replace with your own deployment)
VITE_IMAGE_2_PAINT_URL=https://your-image2paint-service.example.com

# Google OAuth client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Google OAuth callback URL (must match Google Cloud Console setting)
VITE_GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
